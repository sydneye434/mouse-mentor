# Developed by Sydney Edwards
# Copy to backend/.env — never commit .env
#
# --- Database (PostgreSQL in production; Render injects DATABASE_URL) ---
# Local: use a Postgres URL or leave unset to use SQLite file ./local.db
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/mousementor
#
# --- Auth (required in production; Render can generate JWT_SECRET_KEY) ---
# JWT_SECRET_KEY=your-long-random-secret-min-32-chars
#
# --- CORS (comma-separated origins; include your Vercel URL) ---
# CORS_ORIGINS=https://your-app.vercel.app,http://localhost:5173
#
# --- AI (see README) ---
# AI_PROVIDER=groq
# GROQ_API_KEY=
# GROQ_MODEL=llama-3.1-8b-instant
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash
#
# --- Rate limiting (slowapi; POST /chat: 30/hour authed, 5/hour by IP) ---
# RATELIMIT_ENABLED=true
#
# --- Stripe (Pro one-time checkout; use test keys in development) ---
# STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...
# STRIPE_PRICE_ID=price_...   # one-time Price for $12 Pro (Dashboard → Products)
#
# --- Dining alerts (background poll + email) ---
# POLL_INTERVAL_SECONDS=240
# DISABLE_DINING_POLL=false
# DINING_POLL_INTERNAL_KEY=optional-secret-for-GET-/dining/check-availability
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=app-password
# EMAIL_FROM=your-email@gmail.com
#
# --- Optional ---
# ENVIRONMENT=development
# SQL_ECHO=false
